        <Setter Property="CornerRadius" Value="{DynamicResource RadiusControl}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />
